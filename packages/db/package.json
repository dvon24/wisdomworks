{
  "name": "@wisdomworks/db",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.0",
    "postgres": "^3.4.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/uuid": "^11.0.0",
    "@wisdomworks/eslint-config": "workspace:*",
    "@wisdomworks/typescript-config": "workspace:*",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.39.4",
    "vitest": "^4.1.4"
  }
}
